# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1-mini

# ── SMTP sending ──────────────────────────────────────────────────────────────
SMTP_HOST=mail.recruitagents.net
SMTP_PORT=465
# Display name in From: (RFC 5322). If unset, defaults to HireQuotient. Use FROM_NAME= with no value to derive a name from each pool address instead.
FROM_NAME=HireQuotient
DAILY_LIMIT=150
# Per-sender hourly cap (set 5 below provider limit to leave buffer)
HOURLY_LIMIT=95
HOURLY_BUFFER=5
# Optional inter-send delay in seconds (0 = no delay, max throughput)
SEND_DELAY_SECONDS=0
# Socket + connect timeout (seconds). Prevents indefinite hangs → [Errno 60] on macOS.
SMTP_TIMEOUT=20
# Retries per message on transient SMTP/network errors (exponential backoff between attempts).
SMTP_MAX_RETRIES=3

# ── Sender pool  (email:password pairs, comma-separated) ──────────────────────
SENDER_POOL=sender1@yourdomain.com:password1,sender2@yourdomain.com:password2

# ── Deliverability (optional) ───────────────────────────────────────────────────
SUPPRESSION_FILE=suppression.txt
UNSUBSCRIBE_MAILTO=privacy@yourdomain.com
UNSUBSCRIBE_FOOTER_ENABLED=true
# Plain-text signature appended automatically by sender
SIGNATURE_ENABLED=true
SIGNATURE_CLOSING=Best,
SIGNATURE_NAME=Ashutosh Sharma
SIGNATURE_TITLE=
# Optional: leave empty to omit company in signature block
SIGNATURE_COMPANY=
# Optional: leave empty to omit email from signature block
SIGNATURE_EMAIL=
# Optional HTTPS URI for List-Unsubscribe (in addition to mailto)
# UNSUBSCRIBE_URL=https://yourdomain.com/unsubscribe

# ── Agent (batch runner) ──────────────────────────────────────────────────────
# SMTP send thread pool (phase 2).
MAX_WORKERS=5
# OpenAI generation thread pool (phase 1).
LLM_MAX_CONCURRENT=20
# Max simultaneous SMTP sessions across the pool (semaphore around send).
CONCURRENT_SENDS=5
# IST-rotating log directory and how many days of log files to keep.
LOG_DIR=logs
LOG_KEEP_DAYS=7
# OpenAI client defaults (seconds / built-in retries).
OPENAI_TIMEOUT=30
OPENAI_MAX_RETRIES=2
PROSPECTS_FILE=prospects.csv
SENT_LOG_FILE=sent_log.csv
# 0 = process all pending. Set e.g. 5 while testing (limits how many get drafted + sent).
# Deprecated: use --limit N flag on agent.py instead.
PROSPECTS_MAX=0
