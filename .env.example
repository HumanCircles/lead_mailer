# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1-mini

# ── SMTP sending ──────────────────────────────────────────────────────────────
SMTP_HOST=mail.recruitagents.net
SMTP_PORT=465
FROM_NAME=HireQuotient
DAILY_LIMIT=150

# ── Sender pool  (email:password pairs, comma-separated) ──────────────────────
SENDER_POOL=sender1@yourdomain.com:password1,sender2@yourdomain.com:password2

# ── Agent (batch runner) ──────────────────────────────────────────────────────
MAX_WORKERS=20
LLM_MAX_CONCURRENT=40
PROSPECTS_FILE=prospects.csv
SENT_LOG_FILE=sent_log.csv
