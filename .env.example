# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1-mini

# ── SendGrid accounts (domain:api_key:pool_name — comma-separated) ─────────────
# Each entry maps a sender domain to a SendGrid subaccount + IP pool.
# Senders in SENDER_POOL are routed to the matching account by email domain.
SENDGRID_ACCOUNTS=the-easygrowth.us:SG.xxxx:encompass,superchargedai.org:SG.yyyy:nucleus,recruitagents.net:SG.zzzz:nucleus

# Default fallback (used if a sender domain isn't in SENDGRID_ACCOUNTS)
# SENDGRID_API_KEY=SG.xxx
# SENDGRID_IP_POOL=nucleus

# ── Sender pool (email addresses — no passwords needed with SendGrid) ──────────
# Format: email1@domain.com,email2@domain.com,...
# Old format email:password still accepted (password is ignored).
SENDER_POOL=sender1@recruitagents.net,sender2@the-easygrowth.us,sender3@superchargedai.org

# Display name in From: header. If unset, defaults to HireQuotient.
FROM_NAME=HireQuotient

# ── Rate limits ───────────────────────────────────────────────────────────────
DAILY_LIMIT=1000
HOURLY_LIMIT=300
HOURLY_BUFFER=10
# Optional inter-send delay in seconds (0 = no delay, max throughput)
SEND_DELAY_SECONDS=0

# ── Deliverability ────────────────────────────────────────────────────────────
SUPPRESSION_FILE=suppression.txt
UNSUBSCRIBE_MAILTO=privacy@recruitagents.net
UNSUBSCRIBE_FOOTER_ENABLED=true
# UNSUBSCRIBE_URL=https://yourdomain.com/unsubscribe
SIGNATURE_ENABLED=true
SIGNATURE_CLOSING=Best,
SIGNATURE_NAME=Ashutosh Sharma
SIGNATURE_TITLE=
SIGNATURE_COMPANY=
SIGNATURE_EMAIL=

# ── Admin seed email (sent after every run) ───────────────────────────────────
SEED_EMAIL=ashutosh@HireQuotient.com

# ── Agent (batch runner) ──────────────────────────────────────────────────────
MAX_WORKERS=5
LLM_MAX_CONCURRENT=20
CONCURRENT_SENDS=5
LOG_DIR=logs
LOG_KEEP_DAYS=7
OPENAI_TIMEOUT=30
OPENAI_MAX_RETRIES=2
PROSPECTS_FILE=prospects.csv
SENT_LOG_FILE=sent_log.csv
PROSPECTS_MAX=0

# ── IMAP inbox fetch (fetch_inboxes.py only) ──────────────────────────────────
# INBOX_IMAP_SINCE=30-Mar-2026
# INBOX_SINCE_DATE=2026-03-30
